{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}

<div class="row justify-content-center">

    <div class="col-md-5">

        <div class="card shadow-lg p-4 bg-dark text-white rounded-4">

            <h2 class="text-center mb-4 text-info">
                Login
            </h2>

            {# ✅ SHOW LOGIN ERROR (VERY IMPORTANT) #}
            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}">

                <div class="mb-3">
                    <label>Email</label>

                    <input type="email"
                           name="email"
                           value="{{ last_username }}"
                           class="form-control"
                           required>
                </div>

                <div class="mb-3">
                    <label>Password</label>

                    <input type="password"
                           name="password"
                           class="form-control"
                           required>
                </div>

                {# ✅ CSRF TOKEN MUST MATCH AUTHENTICATOR ID #}
                <input type="hidden"
                       name="_csrf_token"
                       value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-info w-100">
                    Login
                </button>

            </form>

            <div class="text-center mt-3">
                <a href="/register" class="text-info">
                    Create account
                </a>
            </div>

        </div>

    </div>

</div>

{% endblock %}