<!DOCTYPE html>
<html>
<head>
    <title>Courses</title>
    <style>
        body { background:#0f172a; color:white; font-family:Arial; }
        .card {
            background:#1e293b;
            padding:15px;
            margin:10px;
            border-radius:10px;
        }
    </style>
</head>
<body>

<h1>🏋️ Available Courses</h1>

{% for c in courses %}
    <div class="card">
        <h3>{{ c.nom }}</h3>
        <p>Coach: {{ c.coach }}</p>
        <p>Date: {{ c.dateCours|date('Y-m-d') }}</p>
    </div>
{% endfor %}

</body>
</html>