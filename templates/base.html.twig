<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Fitness Club{% endblock %}

    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background: #0f172a;
            color:white;
        }

        .navbar{
            background: linear-gradient(90deg,#4f46e5,#7c3aed);
        }

        .card{
            border:none;
            border-radius:20px;
        }

        .btn-purple{
            background:#7c3aed;
            color:white;
        }

        .btn-purple:hover{
            background:#6d28d9;
            color:white;
        }
    </style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark shadow">
    <div class="container">

        <a class="navbar-brand fw-bold" href="/">
            Fitness Club
        </a>

        <div class="d-flex gap-2">

            <a href="/login" class="btn btn-light">
                Login
            </a>

            <a href="/register" class="btn btn-purple">
                Register
            </a>

            <a href="/dashboard" class="btn btn-warning">
                Dashboard
            </a>

        </div>

    </div>
</nav>

<div class="container mt-5">
    {% block body %}{% endblock %}
</div>

</body>
</html>